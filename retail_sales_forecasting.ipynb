    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from statsmodels.tsa.holtwinters import ExponentialSmoothing\n",
    "\n",
    "\n",
    "# Filtrer les données à partir de 2016\n",
    "df_2016 = df[df['observation_date'].dt.year >= 2016]\n",
    "\n",
    "# Lissage exponentiel simple\n",
    "model = ExponentialSmoothing(df_2016['RSXFSN'], trend=None, seasonal=None)\n",
    "fit = model.fit(smoothing_level=0.2, optimized=True)\n",
    "\n",
    "# Prévision sur 16 périodes après la fin de la série\n",
    "forecast = fit.forecast(16)\n",
    "\n",
    "# Graphique\n",
    "plt.figure(figsize=(12,6))\n",
    "plt.plot(df_2016['observation_date'], df_2016['RSXFSN'], linestyle='-', label='Données réelles')\n",
    "plt.plot(df_2016['observation_date'], fit.fittedvalues, linestyle='--', label='Lissage exponentiel')\n",
    "plt.plot(pd.date_range(df_2016['observation_date'].iloc[-1], periods=16+1, freq='M')[1:], forecast, color='red', linestyle='-', label='Prévision 16 périodes')\n",
    "plt.title(\"Série Temporelle avec Lissage Exponentiel et Prévision\")\n",
    "plt.xlabel(\"observation_date\")\n",
    "plt.ylabel(\"RSXFSN\")\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ]
