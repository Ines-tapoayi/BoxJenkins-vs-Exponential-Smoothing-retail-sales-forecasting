   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from statsmodels.tsa.holtwinters import ExponentialSmoothing\n",
    "\n",
    "# Filtrer depuis 2016\n",
    "df = df[df['observation_date'] >= '2016-01-01']\n",
    "\n",
    "# Générer les mois de mars 2023 à août 2025\n",
    "dates_mois = pd.date_range(start='2023-03-01', end='2025-08-01', freq='MS')\n",
    "\n",
    "# Listes pour prévisions et erreurs\n",
    "previsions = []\n",
    "hstep_errors = []\n",
    "\n",
    "for date in dates_mois:\n",
    "    # Données jusqu'au mois précédent\n",
    "    data_train = df[df['observation_date'] < date]['RSXFSN']\n",
    "    \n",
    "    # Observation réelle du mois courant\n",
    "    obs = df[df['observation_date'] == date]['RSXFSN']\n",
    "    \n",
    "    if data_train.empty or obs.empty:\n",
    "        continue\n",
    "    \n",
    "    # Lissage exponentiel\n",
    "    model = ExponentialSmoothing(data_train, trend=None, seasonal=None)\n",
    "    fit = model.fit(smoothing_level=0.2, optimized=True)\n",
    "    \n",
    "    # Prévision du mois courant\n",
    "    pred = fit.forecast(1).values[0]\n",
    "    \n",
    "    # Erreur 0 differences (HSTEPERROR)\n",
    "    error = obs.values[0] - pred\n",
    "    \n",
    "    # Stocker\n",
    "    previsions.append(pred)\n",
    "    hstep_errors.append(error)\n",
    "\n",
    "# Transformer en DataFrame\n",
    "df_hstep = pd.DataFrame({\n",
    "    'Date': dates_mois[:len(previsions)],\n",
    "    'Prévision': previsions,\n",
