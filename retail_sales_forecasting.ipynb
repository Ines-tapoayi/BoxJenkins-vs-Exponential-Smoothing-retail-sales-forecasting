   "source": [
    "import numpy as np\n",
    "from scipy.stats import binomtest  # <-- remplacer binom_test par binomtest\n",
    "\n",
    "# Supposons que HSTEPERROR_test est ta série d'erreurs\n",
    "errors = df_hstep_test['HSTEPERROR_test'].values\n",
    "\n",
    "# Compter les erreurs positives et négatives\n",
    "n_pos = np.sum(errors > 0)\n",
    "n_neg = np.sum(errors < 0)\n",
    "n_total = n_pos + n_neg  # on ignore les erreurs nulles\n",
    "\n",
    "print(f\"Erreurs positives : {n_pos}, Erreurs négatives : {n_neg}\")\n",
    "\n",
    "# Test binomial\n",
    "# H0 : p = 0.5 (autant de + que de -)\n",
    "test_result = binomtest(k=n_pos, n=n_total, p=0.5, alternative='two-sided')\n",
    "\n",
    "print(f\"P-value du test de précision (sign test) : {test_result.pvalue:.4f}\")\n",
    "\n",
    "if test_result.pvalue < 0.05:\n",
    "    print(\"On rejette H0 → le modèle est biaisé\")\n",
    "else:\n",
    "    print(\"On ne rejette pas H0 → pas de biais détecté\")\n"
   ]
  }
