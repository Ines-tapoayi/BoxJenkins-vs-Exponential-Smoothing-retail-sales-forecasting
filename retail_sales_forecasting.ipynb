   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from statsmodels.tsa.holtwinters import ExponentialSmoothing\n",
    "\n",
    "\n",
    "# Créer une colonne trimestre\n",
    "df['Trimestre'] = df['observation_date'].dt.to_period('Q')\n",
    "\n",
    "# Initialiser la liste des prévisions et des observations correspondantes\n",
    "previsions = []\n",
    "observations = []\n",
    "\n",
    "# Boucle trimestre par trimestre de T2 2023 à T3 2025\n",
    "trimestres = pd.period_range('2023Q2', '2025Q3', freq='Q')\n",
    "\n",
    "for trimestre in trimestres:\n",
    "    # Filtrer les données jusqu'au trimestre précédent\n",
    "    data_train = df[df['Trimestre'] < trimestre]['RSXFSN']\n",
    "    \n",
    "    # Filtrer l'observation réelle du trimestre courant\n",
    "    obs = df[df['Trimestre'] == trimestre]['RSXFSN']\n",
    "    \n",
    "    # Si on n'a pas d'observation ou de données d'entraînement, sauter\n",
    "    if data_train.empty or obs.empty:\n",
    "        continue\n",
    "    \n",
    "    # Lissage exponentiel\n",
    "    model = ExponentialSmoothing(data_train, trend=None, seasonal=None)\n",
    "    fit = model.fit(smoothing_level=0.2, optimized=True)\n",
    "    \n",
    "    # Prévision du trimestre courant\n",
    "    pred = fit.forecast(1).values[0]\n",
    "    \n",
    "    # Stocker la prévision et l'observation\n",
    "    previsions.append(pred)\n",
    "    observations.append(obs.values[0])\n",
    "\n",
    "# Calcul du RMSE\n",
    "rmse = np.sqrt(np.mean((np.array(observations) - np.array(previsions))**2))\n",
    "print(f\"RMSE des prévisions trimestre par trimestre : {rmse:.4f}\")\n"
   ]
  },
