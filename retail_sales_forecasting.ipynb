    "import pandas as pd\n",
    "import numpy as np\n",
    "from statsmodels.tsa.holtwinters import ExponentialSmoothing\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "# Filtrer depuis 2016 pour le lissage\n",
    "df_2016 = df[df['observation_date'].dt.year >= 2016]\n",
    "\n",
    "# Lissage exponentiel\n",
    "model = ExponentialSmoothing(df_2016['RSXFSN'], trend=None, seasonal=None)\n",
    "fit = model.fit(smoothing_level=0.2, optimized=True)\n",
    "\n",
    "# Calcul des erreurs\n",
    "df_2016['Erreur'] = df_2016['RSXFSN'] - fit.fittedvalues\n",
    "\n",
    "# Filtrer les erreurs à partir de 2023\n",
    "df_erreur_2023 = df_2016[df_2016['observation_date'].dt.year >= 2023]\n",
    "\n",
    "# Graphique des erreurs\n",
    "plt.figure(figsize=(12,6))\n",
    "plt.plot(df_erreur_2023['observation_date'], df_erreur_2023['Erreur'], color='purple')\n",
    "plt.title(\"Série des Erreurs depuis 2023\")\n",
    "plt.xlabel(\"Date\")\n",
    "plt.ylabel(\"Erreur = Observation - Prévision\")\n",
    "plt.grid(True)\n",
    "plt.show()\n"
   ]
